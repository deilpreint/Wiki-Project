# Подключение к PostgreSQL — реальное значение в server/.env (он в .gitignore)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/wiki_dev?schema=public"

# Секрет для подписи JWT — должен быть длинной случайной строкой
JWT_SECRET="change-me-to-a-long-random-string"

# Порт Express
PORT=4000

# Откуда разрешён CORS (фронтенд)
CLIENT_ORIGIN="http://localhost:5173"